   </Row>
   <Row ss:AutoFitHeight="0">
    <Cell><Data ss:Type="String">loc_15373294129891632403</Data></Cell>
    <Cell><Data ss:Type="String">Subdue Dahl without killing him.</Data></Cell>
    <Cell><Data ss:Type="String">ควบคุมตัว Dahl โดยไม่ฆ่าเขา</Data></Cell>
