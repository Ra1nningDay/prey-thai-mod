    <Cell><Data ss:Type="String">พา Dahl ไปที่ Medical Bay อย่างปลอดภัย</Data></Cell>
    <Cell><Data ss:Type="String">LOCKED</Data></Cell>
   </Row>
   <Row ss:AutoFitHeight="0">
