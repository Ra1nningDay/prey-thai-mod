<?xml version="1.0"?><?mso-application progid="Excel.Sheet"?><Workbook xmlns="urn:schemas-microsoft-com:office:spreadsheet" xmlns:o="urn:schemas-microsoft-com:office:office" xmlns:x="urn:schemas-microsoft-com:office:excel" xmlns:ss="urn:schemas-microsoft-com:office:spreadsheet" xmlns:html="http://www.w3.org/TR/REC-html40"><DocumentProperties xmlns="urn:schemas-microsoft-com:office:office"><Version>16.00</Version></DocumentProperties><OfficeDocumentSettings xmlns="urn:schemas-microsoft-com:office:office"><AllowPNG /></OfficeDocumentSettings><ExcelWorkbook xmlns="urn:schemas-microsoft-com:office:excel"><WindowHeight>11205</WindowHeight><WindowWidth>28245</WindowWidth><WindowTopX>0</WindowTopX><WindowTopY>0</WindowTopY><RefModeR1C1 /><ProtectStructure>False</ProtectStructure><ProtectWindows>False</ProtectWindows></ExcelWorkbook><Styles><Style ss:ID="Default" ss:Name="Normal"><Alignment ss:Vertical="Bottom" /><Borders />&lt;font ss:FontName="Calibri" x:Family="Swiss" ss:Size="11" ss:Color="#000000" /&gt;<Interior /><NumberFormat /><Protection /></Style></Styles><Worksheet ss:Name="LocStuff"><Table x:FullColumns="1" x:FullRows="1" ss:DefaultRowHeight="15"><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">KEY</Data></Cell><Cell><Data ss:Type="String">ORIGINAL TEXT</Data></Cell><Cell><Data ss:Type="String">TRANSLATED TEXT</Data></Cell><Cell><Data ss:Type="String">LOCKED</Data></Cell><Cell><Data ss:Type="String">CHARACTER LIMIT</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">loc_15373294129891630207</Data></Cell><Cell><Data ss:Type="String">First Day on the Job</Data></Cell><Cell><Data ss:Type="String">วันแรกของงาน</Data></Cell><Cell><Data ss:Type="String">LOCKED</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">loc_15373294129891630208</Data></Cell><Cell><Data ss:Type="String">Alex convinced me. I'm going to join him aboard the Talos I space station. The work we're doing up there is too good to pass up. Plus, he says he's got a surprise. I have to jump through some hoops at the training center before I board the shuttle. </Data></Cell><Cell><Data ss:Type="String">อเล็กซ์ชักชวนผมได้แล้ว ผมจะไปเข้าร่วมกับเขาบนสถานีอวกาศ Talos I งานที่เรากำลังทำกันอยู่ที่นั่นน่าสนใจเกินกว่าจะปล่อยผ่านได้ แถมเขายังบอกว่ามีเซอร์ไพรส์ให้ผมด้วย ผมต้องผ่านขั้นตอนบางอย่างที่ศูนย์ฝึกก่อนจะขึ้นชัทเทิล</Data></Cell><Cell><Data ss:Type="String">LOCKED</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">loc_15373294129891630209</Data></Cell><Cell><Data ss:Type="String">Alex convinced me. I'm going to join him aboard the Talos I space station. The work we're doing up there is too good to pass up. Plus, he says he's got a surprise. I have to jump through some hoops at the training center before I board the shuttle. </Data></Cell><Cell><Data ss:Type="String">อเล็กซ์ชักชวนผมได้แล้ว ผมจะไปเข้าร่วมกับเขาบนสถานีอวกาศ Talos I งานที่เรากำลังทำกันอยู่ที่นั่นน่าสนใจเกินกว่าจะปล่อยผ่านได้ แถมเขายังบอกว่ามีเซอร์ไพรส์ให้ผมด้วย ผมต้องผ่านขั้นตอนบางอย่างที่ศูนย์ฝึกก่อนจะขึ้นชัทเทิล</Data></Cell><Cell><Data ss:Type="String">LOCKED</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">loc_15373294129891630210</Data></Cell><Cell><Data ss:Type="String">I showed up for testing at the TranStar building to prep for my ride up to Talos I, but something went horribly wrong. I'm not even sure how to describe what I saw.</Data></Cell><Cell><Data ss:Type="String">ผมมาที่อาคาร TranStar เพื่อเข้ารับการทดสอบก่อนจะเดินทางขึ้นไปยัง Talos I แต่ทุกอย่างกลับผิดพลาดอย่างรุนแรง ผมแทบไม่รู้จะอธิบายสิ่งที่เห็นยังไง</Data></Cell><Cell><Data ss:Type="String">LOCKED</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">loc_15373294129891630211</Data></Cell><Cell><Data ss:Type="String">TranScribe</Data></Cell><Cell><Data ss:Type="String">TranScribe</Data></Cell><Cell><Data ss:Type="String">LOCKED</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">loc_15373294129891630212</Data></Cell><Cell><Data ss:Type="String">Pick up your TranScribe</Data></Cell><Cell><Data ss:Type="String">หยิบ TranScribe ของคุณ</Data></Cell><Cell><Data ss:Type="String">LOCKED</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">loc_15373294129891630213</Data></Cell><Cell><Data ss:Type="String">TranStar Uniform</Data></Cell><Cell><Data ss:Type="String">ชุด TranStar</Data></Cell><Cell><Data ss:Type="String">LOCKED</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">loc_15373294129891630214</Data></Cell><Cell><Data ss:Type="String">Put on your TranStar Uniform</Data></Cell><Cell><Data ss:Type="String">สวมชุด TranStar ของคุณ</Data></Cell><Cell><Data ss:Type="String">LOCKED</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">loc_15373294129891630215</Data></Cell><Cell><Data ss:Type="String">Elevator</Data></Cell><Cell><Data ss:Type="String">ลิฟต์</Data></Cell><Cell><Data ss:Type="String">LOCKED</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">loc_15373294129891630216</Data></Cell><Cell><Data ss:Type="String">Get in the helicopter on the roof</Data></Cell><Cell><Data ss:Type="String">ขึ้นเฮลิคอปเตอร์บนดาดฟ้า</Data></Cell><Cell><Data ss:Type="String">LOCKED</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">loc_15373294129891630217</Data></Cell><Cell><Data ss:Type="String">Helicopter</Data></Cell><Cell><Data ss:Type="String">เฮลิคอปเตอร์</Data></Cell><Cell><Data ss:Type="String">LOCKED</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">loc_15373294129891630218</Data></Cell><Cell><Data ss:Type="String">Get in the helicopter on the roof.</Data></Cell><Cell><Data ss:Type="String">ขึ้นเฮลิคอปเตอร์บนดาดฟ้า</Data></Cell><Cell><Data ss:Type="String">LOCKED</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">loc_15373294129891630219</Data></Cell><Cell><Data ss:Type="String">Helicopter</Data></Cell><Cell><Data ss:Type="String">เฮลิคอปเตอร์</Data></Cell><Cell><Data ss:Type="String">LOCKED</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">loc_15373294129891630220</Data></Cell><Cell><Data ss:Type="String">Enjoy the flight</Data></Cell><Cell><Data ss:Type="String">ขอให้สนุกกับการเดินทาง</Data></Cell><Cell><Data ss:Type="String">LOCKED</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">loc_15373294129891630221</Data></Cell><Cell><Data ss:Type="String">Elevator</Data></Cell><Cell><Data ss:Type="String">ลิฟต์</Data></Cell><Cell><Data ss:Type="String">LOCKED</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">loc_15373294129891630222</Data></Cell><Cell><Data ss:Type="String">Take elevator to the TranStar Welcome Center</Data></Cell><Cell><Data ss:Type="String">ขึ้นลิฟต์ไปยัง TranStar ศูนย์ต้อนรับ</Data></Cell><Cell><Data ss:Type="String">LOCKED</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">loc_15373294129891630223</Data></Cell><Cell><Data ss:Type="String">Welcome Center</Data></Cell><Cell><Data ss:Type="String">ศูนย์ต้อนรับ</Data></Cell><Cell><Data ss:Type="String">LOCKED</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">loc_15373294129891630224</Data></Cell><Cell><Data ss:Type="String">Report to the Test Center</Data></Cell><Cell><Data ss:Type="String">ไปที่ศูนย์ทดสอบ</Data></Cell><Cell><Data ss:Type="String">LOCKED</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">loc_15373294129891630225</Data></Cell><Cell><Data ss:Type="String">Training Area</Data></Cell><Cell><Data ss:Type="String">พื้นที่ฝึกซ้อม</Data></Cell><Cell><Data ss:Type="String">LOCKED</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">loc_15373294129891630226</Data></Cell><Cell><Data ss:Type="String">Complete your tests</Data></Cell><Cell><Data ss:Type="String">ทำการทดสอบของคุณให้เสร็จสิ้น</Data></Cell><Cell><Data ss:Type="String">LOCKED</Data></Cell><Cell><Data ss:Type="String" /></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">loc_15373294129891630227</Data></Cell><Cell><Data ss:Type="String">Fire</Data></Cell><Cell><Data ss:Type="String">ยิง</Data></Cell><Cell><Data ss:Type="String">LOCKED</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">loc_15373294129891630228</Data></Cell><Cell><Data ss:Type="String">Remove the boxes from the red circle</Data></Cell><Cell><Data ss:Type="String">นำกล่องออกจากวงกลมสีแดง</Data></Cell><Cell><Data ss:Type="String">LOCKED</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">loc_15373294129891630229</Data></Cell><Cell><Data ss:Type="String">Hide</Data></Cell><Cell><Data ss:Type="String">ซ่อน</Data></Cell><Cell><Data ss:Type="String">LOCKED</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">loc_15373294129891630230</Data></Cell><Cell><Data ss:Type="String">Hide</Data></Cell><Cell><Data ss:Type="String">ซ่อน</Data></Cell><Cell><Data ss:Type="String">LOCKED</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">loc_15373294129891630231</Data></Cell><Cell><Data ss:Type="String">Switch</Data></Cell><Cell><Data ss:Type="String">สลับ</Data></Cell><Cell><Data ss:Type="String">LOCKED</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">loc_15373294129891630232</Data></Cell><Cell><Data ss:Type="String">Push the blue button</Data></Cell><Cell><Data ss:Type="String">กดปุ่มสีน้ำเงิน</Data></Cell><Cell><Data ss:Type="String">LOCKED</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">loc_15373294129891630233</Data></Cell><Cell><Data ss:Type="String">Take a seat</Data></Cell><Cell><Data ss:Type="String">นั่งลง</Data></Cell><Cell><Data ss:Type="String">LOCKED</Data></Cell></Row></Table><WorksheetOptions xmlns="urn:schemas-microsoft-com:office:excel"><Unsynced /><Selected /><Panes><Pane><Number>3</Number><ActiveRow>16</ActiveRow><ActiveCol>1</ActiveCol><Rang