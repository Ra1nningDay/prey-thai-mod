<?xml version="1.0"?><?mso-application progid="Excel.Sheet"?><Workbook xmlns="urn:schemas-microsoft-com:office:spreadsheet" xmlns:o="urn:schemas-microsoft-com:office:office" xmlns:x="urn:schemas-microsoft-com:office:excel" xmlns:ss="urn:schemas-microsoft-com:office:spreadsheet" xmlns:html="http://www.w3.org/TR/REC-html40"><DocumentProperties xmlns="urn:schemas-microsoft-com:office:office"><Version>16.00</Version></DocumentProperties><OfficeDocumentSettings xmlns="urn:schemas-microsoft-com:office:office"><AllowPNG /></OfficeDocumentSettings><ExcelWorkbook xmlns="urn:schemas-microsoft-com:office:excel"><WindowHeight>13200</WindowHeight><WindowWidth>28800</WindowWidth><WindowTopX>0</WindowTopX><WindowTopY>0</WindowTopY><RefModeR1C1 /><ProtectStructure>False</ProtectStructure><ProtectWindows>False</ProtectWindows></ExcelWorkbook><Styles><Style ss:ID="Default" ss:Name="Normal"><Alignment ss:Vertical="Bottom" /><Borders />&lt;font ss:FontName="Calibri" x:Family="Swiss" ss:Size="11" ss:Color="#000000" /&gt;<Interior /><NumberFormat /><Protection /></Style></Styles><Worksheet ss:Name="LocStuff"><Table ss:ExpandedColumnCount="5" ss:ExpandedRowCount="9" x:FullColumns="1" x:FullRows="1" ss:DefaultRowHeight="15"><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">KEY</Data></Cell><Cell><Data ss:Type="String">ORIGINAL TEXT</Data></Cell><Cell><Data ss:Type="String">TRANSLATED TEXT</Data></Cell><Cell><Data ss:Type="String">LOCKED</Data></Cell><Cell><Data ss:Type="String">CHARACTER LIMIT</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">loc_15373294129891630253</Data></Cell><Cell><Data ss:Type="String">Speak With January</Data></Cell><Cell><Data ss:Type="String">คุยกับ January</Data></Cell><Cell><Data ss:Type="String">LOCKED</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">loc_15373294129891630254</Data></Cell><Cell><Data ss:Type="String">Alex deleted my Looking Glass video before I could finish watching it. An Operator with my voice calling itself January claims it can help me figure out what's going on.</Data></Cell><Cell><Data ss:Type="String">อเล็กซ์ลบวิดีโอ Looking Glass ของผมก่อนที่ผมจะดูจบ Operator ที่ใช้เสียงของผมและเรียกตัวเองว่า January อ้างว่ามันช่วยผมไขเรื่องที่กำลังเกิดขึ้นได้</Data></Cell><Cell><Data ss:Type="String">LOCKED</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">loc_15373294129891630255</Data></Cell><Cell><Data ss:Type="String">Alex deleted my Looking Glass video before I could finish watching it. An Operator with my voice calling itself January gave me a key to access most of the labs off of the Lobby as well as a Neuromod to increase my odds of survival. I'm headed to Deep Storage now.</Data></Cell><Cell><Data ss:Type="String">อเล็กซ์ลบวิดีโอ Looking Glass ของผมก่อนที่ผมจะดูจบ Operator ที่ใช้เสียงของผมและเรียกตัวเองว่า January มอบกุญแจให้ผมเพื่อเข้าถึงห้องแล็บส่วนใหญ่ที่อยู่รอบ ๆ ล็อบบี้ พร้อมกับ Neuromod หนึ่งชิ้นเพื่อเพิ่มโอกาสรอดชีวิต ตอนนี้ผมกำลังมุ่งหน้าไปยัง Deep Storage</Data></Cell><Cell><Data ss:Type="String">LOCKED</Data></Cell><Cell><Data ss:Type="String"></Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">loc_15373294129891630256</Data></Cell><Cell><Data ss:Type="String">January</Data></Cell><Cell><Data ss:Type="String">January</Data></Cell><Cell><Data ss:Type="String">LOCKED</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">loc_15373294129891630257</Data></Cell><Cell><Data ss:Type="String">Speak with January for further instructions.</Data></Cell><Cell><Data ss:Type="String">คุยกับ January เพื่อรับคำสั่งเพิ่มเติม</Data></Cell><Cell><Data ss:Type="String">LOCKED</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">loc_844024417326373783</Data></Cell><Cell><Data ss:Type="String">Search January's remains for further instructions.</Data></Cell><Cell><Data ss:Type="String">ค้นหาซากของ January เพื่อหาคำสั่งเพิ่มเติม</Data></Cell><Cell><Data ss:Type="String">LOCKED</Data></Cell><Cell><Data ss:Type="String"></Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">loc_844024417326373795</Data></Cell><Cell><Data ss:Type="String">January</Data></Cell><Cell><Data ss:Type="String">January</Data></Cell><Cell><Data ss:Type="String">LOCKED</Data></Cell></Row><Row ss:AutoFitHeight="0"><Cell><Data ss:Type="String">loc_844024417326373839</Data></Cell><Cell><Data ss:Type="String">Alex deleted my Looking Glass video before I could finish watching it. An Operator with my voice calling itself January offered me assistance but I destroyed it. Its remains contained a key to access most of the labs off of the Lobby as well as a Neuromod to increase my odds of survival. I'm headed to Deep Storage now.</Data></Cell><Cell><Data ss:Type="String">Alex ลบวิดีโอ Looking Glass ของผมก่อนที่ผมจะดูจบ Operator ที่ใช้เสียงของผมเรียกตัวเองว่า January เสนอความช่วยเหลือให้ผม แต่ผมทำลายมันไปแล้ว ซากของมันมีกุญแจสำหรับเข้าถึงห้องแล็บส่วนใหญ่ที่แยกจาก Lobby รวมถึง Neuromod เพื่อเพิ่มโอกาสรอดชีวิตของผม ตอนนี้ผมกำลังมุ่งหน้าไปที่ Deep Storage</Data></Cell><Cell><Data ss:Type="String">LOCKED</Data></Cell><Cell><Data ss:Type="String"></Data></Cell></Row></Table><WorksheetOptions xmlns="urn:schemas-microsoft-com:office:excel"><Unsynced /><Selected /><Panes><Pane><Number>3</Number><ActiveRow>2</ActiveRow><ActiveCol>3</ActiveCol><RangeSelection>R3C4:R8C4</RangeSelection></Pane></Panes><ProtectObjects>False</ProtectObjects><ProtectScenarios>False</ProtectScenarios></WorksheetOptions></Worksheet><x:ExcelWorkbook /></Workbook>