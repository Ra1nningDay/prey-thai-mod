<?xml version="1.0"?>
<?mso-application progid="Excel.Sheet"?>
<Workbook xmlns:ss="urn:schemas-microsoft-com:office:spreadsheet" xmlns="urn:schemas-microsoft-com:office:spreadsheet">
  <Worksheet ss:Name="Sheet1">
    <Table>
      <Row>
        <Cell>
          <Data ss:Type="String">KEY</Data>
        </Cell>
        <Cell>
          <Data ss:Type="String">ORIGINAL TEXT</Data>
        </Cell>
        <Cell>
          <Data ss:Type="String">TRANSLATED TEXT</Data>
        </Cell>
        <Cell>
          <Data ss:Type="String">LOCKED</Data>
        </Cell>
        <Cell>
          <Data ss:Type="String">CHARACTER LIMIT</Data>
        </Cell>
      </Row>
      <Row>
        <Cell>
          <Data ss:Type="String">BDDB548E552D2428</Data>
        </Cell>
        <Cell>
          <Data ss:Type="String">Good morning, Morgan. I'm Dr. Bellamy. </Data>
        </Cell>
        <Cell>
          <Data ss:Type="String">อรุณสวัสดิ์ Morgan ผม ดร. เบลลามี</Data>
        </Cell>
      </Row>
      <Row>
        <Cell>
          <Data ss:Type="String">BDDB548E552D242A</Data>
        </Cell>
        <Cell>
          <Data ss:Type="String">Looks like we have some tests to run through today. </Data>
        </Cell>
        <Cell>
          <Data ss:Type="String">ดูเหมือนว่าวันนี้เรามีบททดสอบให้ทำ</Data>
        </Cell>
      </Row>
      <Row>
        <Cell>
          <Data ss:Type="String">BDDB548E552D242B</Data>
        </Cell>
        <Cell>
          <Data ss:Type="String">Probably not the kind of thing you're used to, I imagine. But, trust me, you're going to do fantastic.</Data>
        </Cell>
        <Cell>
          <Data ss:Type="String">ผมคิดว่าคงไม่ใช่สิ่งที่คุณคุ้นเคย แต่เชื่อผมเถอะ คุณจะทำได้ยอดเยี่ยม</Data>
        </Cell>
      </Row>
      <Row>
        <Cell>
          <Data ss:Type="String">BDDB548E552D242C</Data>
        </Cell>
        <Cell>
          <Data ss:Type="String">You're going to do fantastic.</Data>
        </Cell>
        <Cell>
          <Data ss:Type="String">คุณจะทำได้ยอดเยี่ยม</Data>
        </Cell>
      </Row>
      <Row>
        <Cell>
          <Data ss:Type="String">BDDB548E552D242D</Data>
        </Cell>
        <Cell>
          <Data ss:Type="String">All good? Great. Let's begin. </Data>
        </Cell>
        <Cell>
          <Data ss:Type="String">ทุกอย่างเรียบร้อยดีไหม เยี่ยม มาเริ่มกันเลย</Data>
        </Cell>
      </Row>
      <Row>
        <Cell>
          <Data ss:Type="String">BDDB548E552D242E</Data>
        </Cell>
        <Cell>
          <Data ss:Type="String">Do you see those little boxes? Wonderful. </Data>
        </Cell>
        <Cell>
          <Data ss:Type="String">คุณเห็นกล่องเล็ก ๆ พวกนั้นไหม ยอดเยี่ยม</Data>
        </Cell>
      </Row>
      <Row>
        <Cell>
          <Data ss:Type="String">BDDB548E552D242F</Data>
        </Cell>
        <Cell>
          <Data ss:Type="String">For this first test, I'd like you to remove the boxes from the red circle as quickly as you can. </Data>
        </Cell>
        <Cell>
          <Data ss:Type="String">สำหรับการทดสอบแรกนี้ ผมอยากให้คุณนำกล่องออกจากวงกลมสีแดงให้เร็วที่สุดเท่าที่จะทำได้</Data>
        </Cell>
      </Row>
      <Row>
        <Cell>
          <Data ss:Type="String">BDDB548E552D2431</Data>
        </Cell>
        <Cell>
          <Data ss:Type="String">Take your time, relax. Think it over. </Data>
        </Cell>
        <Cell>
          <Data ss:Type="String">ไม่ต้องรีบร้อน ผ่อนคลาย คิดให้ดี</Data>
        </Cell>
      </Row>
      <Row>
        <Cell>
          <Data ss:Type="String">BDDB548E552D2432</Data>
        </Cell>
        <Cell>
          <Data ss:Type="String">No, I'm kidding. You only have five seconds.</Data>
        </Cell>
        <Cell>
          <Data ss:Type="String">ไม่ ผมล้อเล่น คุณมีเวลาแค่ห้าวินาที</Data>
        </Cell>
      </Row>
      <Row>
        <Cell>
          <Data ss:Type="String">BDDB548E552D24B9</Data>
        </Cell>
        <Cell>
          <Data ss:Type="String">No, I'm kidding. You only have three seconds.</Data>
        </Cell>
        <Cell>
          <Data ss:Type="String">ไม่ ผมล้อเล่น คุณมีเวลาแค่สามวินาที</Data>
        </Cell>
      </Row>
      <Row>
        <Cell>
          <Data ss:Type="String">BDDB548E552D250F</Data>
        </Cell>
        <Cell>
          <Data ss:Type="String">Hit the red button when you're ready to start.</Data>
        </Cell>
        <Cell>
          <Data ss:Type="String">กดปุ่มสีแดงเมื่อคุณพร้อมที่จะเริ่ม</Data>
        </Cell>
      </Row>
      <Row>
        <Cell>
          <Data ss:Type="String">BDDB548E552D2528</Data>
        </Cell>
        <Cell>
          <Data ss:Type="String">Wonderful. That's... you're absolutely fine. Let's move on to Room B then.</Data>
        </Cell>
        <Cell>
          <Data ss:Type="String">ยอดเยี่ยม นั่น... คุณทำได้ดีมาก ถ้าอย่างนั้นเราไปที่ Room B กันเลย</Data>
        </Cell>
      </Row>
      <Row>
        <Cell>
          <Data ss:Type="String">BDDB548E552D254B</Data>
        </Cell>
        <Cell>
          <Data ss:Type="String">Ok, Morgan. Listen carefully. I'd like you to do your best to hide in this room.</Data>
        </Cell>
        <Cell>
          <Data ss:Type="String">โอเค Morgan ฟังให้ดี ผมอยากให้คุณพยายามซ่อนตัวในห้องนี้ให้ดีที่สุด</Data>
        </Cell>
      </Row>
      <Row>
        <Cell>
          <Data ss:Type="String">BDDB548E552D254C</Data>
        </Cell>
        <Cell>
          <Data ss:Type="String">Just go with your gut. Okay? Wonderful. Press the red button when you're ready.</Data>
        </Cell>
        <Cell>
          <Data ss:Type="String">ทำตามสัญชาตญาณของคุณ โอเคไหม ยอดเยี่ยม กดปุ่มสีแดงเมื่อคุณพร้อม</Data>
        </Cell>
      </Row>
      <Row>
        <Cell>
          <Data ss:Type="String">BDDB548E552D254D</Data>
        </Cell>
        <Cell>
          <Data ss:Type="String">Hmph. I ...</Data>
        </Cell>
        <Cell>
          <Data ss:Type="String">หึม ผม...</Data>
        </Cell>
      </Row>
      <Row>
        <Cell>
          <Data ss:Type="String">BDDB548E552D254E</Data>
        </Cell>
        <Cell>
          <Data ss:Type="String">Can we reset? No? That's fine.</Data>
        </Cell>
        <Cell>
          <Data ss:Type="String">เราจะรีเซ็ตได้ไหม ไม่ได้เหรอ ไม่เป็นไร</Data>
        </Cell>
      </Row>
      <Row>
        <Cell>
          <Data ss:Type="String">BDDB548E552D254F</Data>
        </Cell>
        <Cell>
          <Data ss:Type="String">Sorry. Let's keep things moving, Morgan. Head into Room C. You're doing marvelous. </Data>
        </Cell>
        <Cell>
          <Data ss:Type="String">ขอโทษที เรามาทำต่อกันเถอะ Morgan เข้าไปใน Room C คุณทำได้ยอดเยี่ยมมาก</Data>
        </Cell>
      </Row>
      <Row>
        <Cell>
          <Data ss:Type="String">BDDB548E552D25D5</Data>
        </Cell>
        <Cell>
          <Data ss:Type="String">All right. Here we go. </Data>
        </Cell>
        <Cell>
          <Data ss:Type="String">เอาล่ะ มาเริ่มกันเลย</Data>
        </Cell>
      </Row>
      <Row>
        <Cell>
          <Data ss:Type="String">BDDB548E552D25D6</Data>
        </Cell>
        <Cell>
          <Data ss:Type="String">For this test, please press the blue button across the room as quickly as you can, in the most natural intuitive way possible.</Data>
        </Cell>
        <Cell>
          <Data ss:Type="String">สำหรับการทดสอบนี้ โปรดกดปุ่มสีน้ำเงินที่อยู่อีกฝั่งของห้องให้เร็วที่สุดเท่าที่จะทำได้ ด้วยวิธีที่เป็นธรรมชาติและสัญชาตญาณที่สุด</Data>
        </Cell>
      </Row>
      <Row>
        <Cell>
          <Data ss:Type="String">BDDB548E552D25D7</Data>
        </Cell>
        <Cell>
          <Data ss:Type="String">Without thinking. Just ... go for it. </Data>
        </Cell>
        <Cell>
          <Data ss:Type="String">ไม่ต้องคิด แค่... ทำเลย</Data>
        </Cell>
      </Row>
      <Row>
        <Cell>
          <Data ss:Type="String">BDDB548E552D25D8</Data>
        </Cell>
        <Cell>
          <Data ss:Type="String">Press the red button when you're ready.</Data>
        </Cell>
        <Cell>
          <Data ss:Type="String">กดปุ่มสีแดงเมื่อคุณพร้อม</Data>
        </Cell>
      </Row>
      <Row>
        <Cell>
          <Data ss:Type="String">BDDB548E552D25D9</Data>
        </Cell>
        <Cell>
          <Data ss:Type="String">I'm sorry, can someone please explain to me what's happening? Simmons?</Data>
        </Cell>
        <Cell>
          <Data ss:Type="String">ขอโทษนะ ใครช่วยอธิบายหน่อยได้ไหมว่าเกิดอะไรขึ้น Simmons?</Data>
        </Cell>
      </Row>
      <Row>
        <Cell>
          <Data ss:Type="String">BDDB548E552D25E6</Data>
        </Cell>
        <Cell>
          <Data ss:Type="String">Did you double-check?</Data>
        </Cell>
        <Cell>
          <Data ss:Type="String">คุณตรวจสอบซ้ำแล้วใช่ไหม</Data>
        </Cell>
      </Row>
      <Row>
        <Cell>
          <Data ss:Type="String">BDDB548E552D2657</Data>
        </Cell>
        <Cell>
          <Data ss:Type="String">I apologize Morgan, we're having some trouble with... the equipment. </Data>
        </Cell>
        <Cell>
          <Data ss:Type="String">ผมขอโทษ Morgan เรากำลังมีปัญหาบางอย่างกับ... อุปกรณ์</Data>
        </Cell>
      </Row>
      <Row>
        <Cell>
          <Data ss:Type="String">BDDB548E552D2658</Data>
        </Cell>
        <Cell>
          <Data ss:Type="String">Not your fault. You're doing fabulous, actually. One last room. Let's step into D.</Data>
        </Cell>
        <Cell>
          <Data ss:Type="String">ไม่ใช่ความผิดของคุณ จริง ๆ แล้วคุณทำได้ยอดเยี่ยมมาก เหลืออีกห้องเดียว ไปที่ Room D กันเถอะ</Data>
        </Cell>
      </Row>
      <Row>
        <Cell>
          <Data ss:Type="String">BDDB548E552D2659</Data>
        </Cell>
        <Cell>
          <Data ss:Type="String">Can someone get me a cup of coffee? I would appreciate it. Thank you. </Data>
        </Cell>
        <Cell>
          <Data ss:Type="String">ใครช่วยเอาถ้วยกาแฟมาให้ผมหน่อยได้ไหม ผมจะขอบคุณมาก ขอบคุณ</Data>
        </Cell>
      </Row>
      <Row>
        <Cell>
          <Data ss:Type="String">BDDB548E552D269A</Data>
        </Cell>
        <Cell>
          <Data ss:Type="String">Ok, Morgan. Have a seat at the table for me, please.</Data>
        </Cell>
        <Cell>
          <Data ss:Type="String">โอเค Morgan กรุณานั่งที่โต๊ะให้ผมหน่อย</Data>
        </Cell>
      </Row>
      <Row>
        <Cell>
          <Data ss:Type="String">BDDB548E552D269B</Data>
        </Cell>
        <Cell>
          <Data ss:Type="String">Wonderful job. Take a look at the screen in front of you.</Data>
        </Cell>
        <Cell>
          <Data ss:Type="String">ทำได้ยอดเยี่ยมมาก ดูหน้าจอตรงหน้าคุณสิ</Data>
        </Cell>
      </Row>
      <Row>
        <Cell>
          <Data ss:Type="String">BDDB548E552D269C</Data>
        </Cell>
        <Cell>
          <Data ss:Type="String">I'm going to show you a series of questions. Pick the answer that makes the most sense to you. </Data>
        </Cell>
        <Cell>
          <Data ss:Type="String">ผมจะแสดงชุดคำถามให้คุณดู เลือกคำตอบที่คุณคิดว่าสมเหตุสมผลที่สุด</Data>
        </Cell>
      </Row>
      <Row>
        <Cell>
          <Data ss:Type="String">BDDB548E552D269D</Data>
        </Cell>
        <Cell>
          <Data ss:Type="String">Press start on the screen when you're ready.</Data>
        </Cell>
        <Cell>
          <Data ss:Type="String">กดเริ่มบนหน้าจอเมื่อคุณพร้อม</Data>
        </Cell>
      </Row>
      <Row>
        <Cell>
          <Data ss:Type="String">BDDB548E552D26C9</Data>
        </Cell>
        <Cell>
          <Data ss:Type="String">Good. Looks like you've got the hang of it. Keep going.</Data>
        </Cell>
        <Cell>
          <Data ss:Type="String">ดี ดูเหมือนคุณจะเข้าใจแล้ว ทำต่อไป</Data>
        </Cell>
      </Row>
      <Row>
        <Cell>
          <Data ss:Type="String">BDDB548E552D26CA</Data>
        </Cell>
        <Cell>
          <Data ss:Type="String">Oh, that's heavy stuff.</Data>
        </Cell>
        <Cell>
          <Data ss:Type="String">โอ้ นั่นมันเรื่องหนักหนา</Data>
        </Cell>
      </Row>
      <Row>
        <Cell>
          <Data ss:Type="String">BDDB548E552D26CB</Data>
        </Cell>
        <Cell>
          <Data ss:Type="String">(Grunt)</Data>
        </Cell>
        <Cell>
          <Data ss:Type="String">(เสียงคราง)</Data>
        </Cell>
      </Row>
      <Row>
        <Cell>
          <Data ss:Type="String">BDDB548E552D26CC</Data>
        </Cell>
        <Cell>
          <Data ss:Type="String">Good. Next.</Data>
        </Cell>
        <Cell>
          <Data ss:Type="String">ดี ต่อไป</Data>
        </Cell>
      </Row>
      <Row>
        <Cell>
          <Data ss:Type="String">BDDB548E552D26CD</Data>
        </Cell>
        <Cell>
          <Data ss:Type="String">Almost done.</Data>
        </Cell>
        <Cell>
          <Data ss:Type="String">ใกล้เสร็จแล้ว</Data>
        </Cell>
      </Row>
      <Row>
        <Cell>
          <Data ss:Type="String">BDDB548E552D26CE</Data>
        </Cell>
        <Cell>
          <Data ss:Type="String">Well done, well done. We're nearly through it. For this next part, I'm going to display an image.</Data>
        </Cell>
        <Cell>
          <Data ss:Type="String">ทำได้ดีมาก ทำได้ดีมาก เราใกล้จะเสร็จแล้ว สำหรับส่วนต่อไปนี้ ผมจะแสดงรูปภาพให้ดู</Data>
        </Cell>
      </Row>
      <Row>
        <Cell>
          <Data ss:Type="String">BDDB548E552D2729</Data>
        </Cell>
        <Cell>
          <Data ss:Type="String">I want you to take a good look at it. In a moment I'm going to ask you what ... uh...</Data>
        </Cell>
        <Cell>
          <Data ss:Type="String">ผมอยากให้คุณดูมันให้ดี อีกสักครู่ผมจะถามคุณว่า... เอ่อ...</Data>
        </Cell>
      </Row>
      <Row>
        <Cell>
          <Data ss:Type="String">BDDB548E552D2755</Data>
        </Cell>
        <Cell>
          <Data ss:Type="String">This my coffee? It's empty.</Data>
        </Cell>
        <Cell>
          <Data ss:Type="String">นี่กาแฟผมเหรอ มันว่างเปล่า</Data>
        </Cell>
      </Row>
      <Row>
        <Cell>
          <Data ss:Type="String">BDDB548E552D2758</Data>
        </Cell>
        <Cell>
          <Data ss:Type="String">(Choking)</Data>
        </Cell>
        <Cell>
          <Data ss:Type="String">(สำลัก)</Data>
        </Cell>
      </Row>
      <Row>
        <Cell>
          <Data ss:Type="String">BDDB548E552D2791</Data>
        </Cell>
        <Cell>
          <Data ss:Type="String">Whenever you're ready, Morgan.</Data>
        </Cell>
        <Cell>
          <Data ss:Type="String">เมื่อคุณพร้อม Morgan</Data>
        </Cell>
      </Row>
      <Row>
        <Cell>
          <Data ss:Type="String">BDDB548E552D27B6</Data>
        </Cell>
        <Cell>
          <Data ss:Type="String">Just press the red button.</Data>
        </Cell>
        <Cell>
          <Data ss:Type="String">แค่กดปุ่มสีแดง</Data>
        </Cell>
      </Row>
      <Row>
        <Cell>
          <Data ss:Type="String">BDDB548E552D27BC</Data>
        </Cell>
        <Cell>
          <Data ss:Type="String">The red button starts the test.</Data>
        </Cell>
        <Cell>
          <Data ss:Type="String">ปุ่มสีแดงจะเริ่มการทดสอบ</Data>
        </Cell>
      </Row>
      <Row>
        <Cell>
          <Data ss:Type="String">BDDB548E552D27BE</Data>
        </Cell>
        <Cell>
          <Data ss:Type="String">Is it warm in here? </Data>
        </Cell>
        <Cell>
          <Data ss:Type="String">ที่นี่อากาศร้อนไหม</Data>
        </Cell>
      </Row>
      <Row>
        <Cell>
          <Data ss:Type="String">BDDB548E552D27BF</Data>
        </Cell>
        <Cell>
          <Data ss:Type="String">Dr. Yu? Morgan. We're ready.</Data>
        </Cell>
        <Cell>
          <Data ss:Type="String">ดร. Yu? Morgan เราพร้อมแล้ว</Data>
        </Cell>
      </Row>
      <Row>
        <Cell>
          <Data ss:Type="String">BDDB548E552D27F3</Data>
        </Cell>
        <Cell>
          <Data ss:Type="String">Did you see what they had in the cafeteria this morning? Crepes.</Data>
        </Cell>
        <Cell>
          <Data ss:Type="String">คุณเห็นไหมว่าเมื่อเช้าโรงอาหารมีอะไร เครป</Data>
        </Cell>
      </Row>
      <Row>
        <Cell>
          <Data ss:Type="String">BDDB548E552D2810</Data>
        </Cell>
        <Cell>
          <Data ss:Type="String">(Cough)</Data>
        </Cell>
        <Cell>
          <Data ss:Type="String">(ไอ)</Data>
        </Cell>
      </Row>
      <Row>
        <Cell>
          <Data ss:Type="String">BDDB548E5530210C</Data>
        </Cell>
        <Cell>
          <Data ss:Type="String">(Sigh)</Data>
        </Cell>
        <Cell>
          <Data ss:Type="String">(ถอนหายใจ)</Data>
        </Cell>
      </Row>
      <Row>
        <Cell>
          <Data ss:Type="String">BDDB548E558C9304</Data>
        </Cell>
        <Cell>
          <Data ss:Type="String">Interesting.</Data>
        </Cell>
        <Cell>
          <Data ss:Type="String">น่าสนใจ</Data>
        </Cell>
      </Row>
      <Row>
        <Cell>
          <Data ss:Type="String">BDDB548E558C9331</Data>
        </Cell>
        <Cell>
          <Data ss:Type="String">Wow. I'm... impressed.</Data>
        </Cell>
        <Cell>
          <Data ss:Type="String">ว้าว ผม... ประทับใจ</Data>
        </Cell>
      </Row>
      <Row>
        <Cell>
          <Data ss:Type="String">BDDB548E558C941A</Data>
        </Cell>
        <Cell>
          <Data ss:Type="String">You know what? I'd probably do the same thing.</Data>
        </Cell>
        <Cell>
          <Data ss:Type="String">รู้อะไรไหม ผมก็คงทำแบบเดียวกัน</Data>
        </Cell>
      </Row>
      <Row>
        <Cell>
          <Data ss:Type="String">BDDB548E558C9524</Data>
        </Cell>
        <Cell>
          <Data ss:Type="String">Not your problem, right?</Data>
        </Cell>
        <Cell>
          <Data ss:Type="String">ไม่ใช่ปัญหาของคุณใช่ไหม</Data>
        </Cell>
      </Row>
      <Row>
        <Cell>
          <Data ss:Type="String">BDDB548E559304AA</Data>
        </Cell>
        <Cell>
          <Data ss:Type="String">Any... synaptic register? At all? No? That's fine.</Data>
        </Cell>
        <Cell>
          <Data ss:Type="String">มีการลงทะเบียนไซแนปส์... บ้างไหม เลยเหรอ ไม่เหรอ ไม่เป็นไร</Data>
        </Cell>
      </Row>
      <Row>
        <Cell>
          <Data ss:Type="String">BDDB548E563CAFA9</Data>
        </Cell>
        <Cell>
          <Data ss:Type="String">Morgan. We can see you there.</Data>
        </Cell>
        <Cell>
          <Data ss:Type="String">Morgan เราเห็นคุณอยู่ตรงนั้น</Data>
