      <Row>
        <Cell>
          <Data ss:Type="String">BDDB548E56C13361</Data>
        </Cell>
        <Cell>
          <Data ss:Type="String">Search results... subject not found.</Data>
        </Cell>
        <Cell>
          <Data ss:Type="String">ผลการค้นหา... ไม่พบเป้าหมาย</Data>
        </Cell>
      </Row>
      <Row>
        <Cell>
          <Data ss:Type="String">BDDB548E56C158FE</Data>
        </Cell>
        <Cell>
          <Data ss:Type="String">Typhon Anthrophantasmus. Metempsychotic remainder organism.  </Data>
        </Cell>
        <Cell>
          <Data ss:Type="String">Typhon Anthrophantasmus สิ่งมีชีวิตที่เหลืออยู่จากการกลับชาติมาเกิด</Data>
        </Cell>
      </Row>
      <Row>
        <Cell>
          <Data ss:Type="String">BDDB548E56C15959</Data>
        </Cell>
        <Cell>
          <Data ss:Type="String">Next entry. Typhon Cacoplasmus. Common name, mimic. Indexing...</Data>
        </Cell>
        <Cell>
          <Data ss:Type="String">รายการถัดไป Typhon Cacoplasmus ชื่อสามัญ, Mimic กำลังจัดทำดัชนี...</Data>
        </Cell>
      </Row>
      <Row>
        <Cell>
          <Data ss:Type="String">BDDB548E56C15EA9</Data>
        </Cell>
        <Cell>
          <Data ss:Type="String">There is no ought...there is no [voice malfunctioning]</Data>
        </Cell>
        <Cell>
          <Data ss:Type="String">ไม่มีสิ่งที่ควรจะเป็น...ไม่มี [เสียงขัดข้อง]</Data>
        </Cell>
      </Row>
      <Row>
        <Cell>
          <Data ss:Type="String">BDDB548E56C350FC</Data>
        </Cell>
        <Cell>
          <Data ss:Type="String">[quick warning beeps]</Data>
        </Cell>
        <Cell>
          <Data ss:Type="String">[เสียงบี๊บเตือนเร็วๆ]</Data>
        </Cell>
      </Row>
      <Row>
        <Cell>
          <Data ss:Type="String">BDDB548E56C3512F</Data>
        </Cell>
        <Cell>
          <Data ss:Type="String">[quick warning beeps]</Data>
        </Cell>
        <Cell>
          <Data ss:Type="String">[เสียงบี๊บเตือนเร็วๆ]</Data>
        </Cell>
      </Row>
      <Row>
        <Cell>
          <Data ss:Type="String">BDDB548E56C35165</Data>
        </Cell>
        <Cell>
          <Data ss:Type="String">I'm sure you didn't intend that.</Data>
        </Cell>
        <Cell>
          <Data ss:Type="String">ผมแน่ใจว่าคุณไม่ได้ตั้งใจ</Data>
        </Cell>
      </Row>
      <Row>
        <Cell>
          <Data ss:Type="String">BDDB548E56C35172</Data>
        </Cell>
        <Cell>
          <Data ss:Type="String">Are you aware you harmed me?</Data>
        </Cell>
        <Cell>
          <Data ss:Type="String">คุณรู้ตัวไหมว่าคุณทำร้ายผม?</Data>
        </Cell>
      </Row>
      <Row>
        <Cell>
          <Data ss:Type="String">BDDB548E56C351AD</Data>
        </Cell>
        <Cell>
          <Data ss:Type="String">I observe that you damaged me.</Data>
        </Cell>
        <Cell>
          <Data ss:Type="String">ผมสังเกตว่าคุณทำให้ผมเสียหาย</Data>
        </Cell>
      </Row>
      <Row>
        <Cell>
          <Data ss:Type="String">BDDB548E56C351E8</Data>
        </Cell>
        <Cell>
          <Data ss:Type="String">Please stop.</Data>
        </Cell>
        <Cell>
          <Data ss:Type="String">โปรดหยุด</Data>
        </Cell>
      </Row>
      <Row>
        <Cell>
          <Data ss:Type="String">BDDB548E56C3765E</Data>
        </Cell>
        <Cell>
          <Data ss:Type="String">[operator malfunctioning]</Data>
        </Cell>
        <Cell>
          <Data ss:Type="String">[Operator ขัดข้อง]</Data>
        </Cell>
      </Row>
      <Row>
        <Cell>
          <Data ss:Type="String">BDDB548E56C376F8</Data>
        </Cell>
        <Cell>
          <Data ss:Type="String">Hello, Dr. Yu.</Data>
        </Cell>
        <Cell>
          <Data ss:Type="String">สวัสดี, Dr. Yu</Data>
        </Cell>
      </Row>
      <Row>
        <Cell>
          <Data ss:Type="String">BDDB548E56C37709</Data>
        </Cell>
        <Cell>
          <Data ss:Type="String">Dr. Yu.</Data>
        </Cell>
        <Cell>
          <Data ss:Type="String">ดร. Yu.</Data>
        </Cell>
      </Row>
      <Row>
        <Cell>
          <Data ss:Type="String">BDDB548E56C37734</Data>
        </Cell>
        <Cell>
          <Data ss:Type="String">Hello.</Data>
        </Cell>
        <Cell>
          <Data ss:Type="String">สวัสดี</Data>
        </Cell>
      </Row>
      <Row>
        <Cell>
          <Data ss:Type="String">BDDB548E56C3777D</Data>
        </Cell>
        <Cell>
          <Data ss:Type="String">Excuse me.</Data>
        </Cell>
        <Cell>
          <Data ss:Type="String">ขอโทษครับ</Data>
        </Cell>
      </Row>
      <Row>
        <Cell>
          <Data ss:Type="String">BDDB548E56C37795</Data>
        </Cell>
        <Cell>
          <Data ss:Type="String">[short beep]</Data>
        </Cell>
        <Cell>
          <Data ss:Type="String">[เสียงบี๊บสั้นๆ]</Data>
        </Cell>
      </Row>
      <Row>
        <Cell>
          <Data ss:Type="String">BDDB548E56C377B3</Data>
        </Cell>
        <Cell>
          <Data ss:Type="String">You probably didn't see me there.</Data>
        </Cell>
        <Cell>
          <Data ss:Type="String">คุณอาจจะไม่เห็นผมตรงนั้น</Data>
        </Cell>
      </Row>
      <Row>
        <Cell>
          <Data ss:Type="String">BDDB548E56C377EB</Data>
        </Cell>
        <Cell>
          <Data ss:Type="String">Should I change position?</Data>
        </Cell>
        <Cell>
          <Data ss:Type="String">ผมควรเปลี่ยนตำแหน่งไหม?</Data>
        </Cell>
      </Row>
      <Row>
        <Cell>
          <Data ss:Type="String">BDDB548E56C37822</Data>
        </Cell>
        <Cell>
          <Data ss:Type="String">[beeping, whirring]</Data>
        </Cell>
        <Cell>
          <Data ss:Type="String">[เสียงบี๊บ, เสียงหมุน]</Data>
        </Cell>
      </Row>
      <Row>
        <Cell>
          <Data ss:Type="String">BDDB548E56C37830</Data>
        </Cell>
        <Cell>
          <Data ss:Type="String">[beeping, whirring]</Data>
        </Cell>
        <Cell>
          <Data ss:Type="String">[เสียงบี๊บ, เสียงหมุน]</Data>
        </Cell>
      </Row>
      <Row>
        <Cell>
          <Data ss:Type="String">BDDB548E56C37911</Data>
        </Cell>
        <Cell>
          <Data ss:Type="String">Scanning...</Data>
        </Cell>
        <Cell>
          <Data ss:Type="String">กำลังสแกน...</Data>
        </Cell>
      </Row>
      <Row>
        <Cell>
          <Data ss:Type="String">BDDB548E56C38149</Data>
        </Cell>
        <Cell>
          <Data ss:Type="String">Current conditions do not allow for safe interaction.</Data>
        </Cell>
        <Cell>
          <Data ss:Type="String">สภาพปัจจุบันไม่อนุญาตให้มีการโต้ตอบที่ปลอดภัย</Data>
        </Cell>
      </Row>
      <Row>
        <Cell>
          <Data ss:Type="String">BDDB548E56C38244</Data>
        </Cell>
        <Cell>
          <Data ss:Type="String">Nueroimaging shows your psychoactive potential is at or near peak level.</Data>
        </Cell>
        <Cell>
          <Data ss:Type="String">การถ่ายภาพระบบประสาทแสดงให้เห็นว่าศักยภาพทางจิตประสาทของคุณอยู่ในระดับสูงสุดหรือใกล้เคียง</Data>
        </Cell>
      </Row>
      <Row>
        <Cell>
          <Data ss:Type="String">BDDB548E56C38795</Data>
        </Cell>
        <Cell>
          <Data ss:Type="String">Neuroimaging shows your mental resources are below peak.</Data>
        </Cell>
        <Cell>
          <Data ss:Type="String">การถ่ายภาพระบบประสาทแสดงให้เห็นว่าทรัพยากรทางจิตของคุณต่ำกว่าระดับสูงสุด</Data>
        </Cell>
      </Row>
      <Row>
        <Cell>
          <Data ss:Type="String">BDDB548E56C387A1</Data>
        </Cell>
        <Cell>
          <Data ss:Type="String">This should help.</Data>
        </Cell>
        <Cell>
          <Data ss:Type="String">นี่น่าจะช่วยได้</Data>
        </Cell>
      </Row>
      <Row>
        <Cell>
          <Data ss:Type="String">BDDB548E56C3A255</Data>
        </Cell>
        <Cell>
          <Data ss:Type="String">Are we conducting an experiment today?</Data>
        </Cell>
        <Cell>
          <Data ss:Type="String">วันนี้เราจะทำการทดลองหรือเปล่า?</Data>
        </Cell>
      </Row>
      <Row>
        <Cell>
          <Data ss:Type="String">BDDB548E56C3A260</Data>
        </Cell>
        <Cell>
          <Data ss:Type="String">[beeping]</Data>
        </Cell>
        <Cell>
          <Data ss:Type="String">[เสียงบี๊บ]</Data>
        </Cell>
      </Row>
      <Row>
        <Cell>
          <Data ss:Type="String">BDDB548E56C3A2A8</Data>
        </Cell>
        <Cell>
          <Data ss:Type="String">Our Laboratory Quality Assurance Plan is up to date.</Data>
        </Cell>
        <Cell>
          <Data ss:Type="String">แผนการประกันคุณภาพห้องปฏิบัติการของเราเป็นปัจจุบันแล้ว</Data>
        </Cell>
      </Row>
      <Row>
        <Cell>
          <Data ss:Type="String">BDDB548E56C3A2B2</Data>
        </Cell>
        <Cell>
          <Data ss:Type="String">Try Deep Storage if you need to access archived data.</Data>
        </Cell>
        <Cell>
          <Data ss:Type="String">ลองไปที่ Deep Storage ถ้าคุณต้องการเข้าถึงข้อมูลที่เก็บถาวร</Data>
        </Cell>
      </Row>
      <Row>
        <Cell>
          <Data ss:Type="String">BDDB548E56C3A2D0</Data>
        </Cell>
        <Cell>
          <Data ss:Type="String">The procedures manual specifies no eating, drinking, or smoking. </Data>
        </Cell>
        <Cell>
          <Data ss:Type="String">คู่มือขั้นตอนระบุว่าห้ามกิน ดื่ม หรือสูบบุหรี่</Data>
        </Cell>
      </Row>
      <Row>
        <Cell>
          <Data ss:Type="String">BDDB548E56C3A2DE</Data>
        </Cell>
        <Cell>
          <Data ss:Type="String">I'm afraid most systems are damaged or locked down at the moment.</Data>
        </Cell>
        <Cell>
          <Data ss:Type="String">ผมเกรงว่าระบบส่วนใหญ่เสียหายหรือถูกล็อกดาวน์ในขณะนี้</Data>
        </Cell>
      </Row>
      <Row>
        <Cell>
          <Data ss:Type="String">BDDB548E56C3A2FC</Data>
        </Cell>
        <Cell>
          <Data ss:Type="String">Calibrating.</Data>
        </Cell>
        <Cell>
          <Data ss:Type="String">กำลังปรับเทียบ</Data>
        </Cell>
      </Row>
      <Row>
        <Cell>
          <Data ss:Type="String">BDDB548E56C3A329</Data>
        </Cell>
        <Cell>
          <Data ss:Type="String">Primarily, I take readings and analyze data. I also provide reference lookups. </Data>
        </Cell>
        <Cell>
          <Data ss:Type="String">หลักๆ แล้ว ผมจะอ่านค่าและวิเคราะห์ข้อมูล ผมยังให้การค้นหาอ้างอิงด้วย</Data>
        </Cell>
      </Row>
      <Row>
        <Cell>
          <Data ss:Type="String">BDDB548E56C3A33C</Data>
        </Cell>
        <Cell>
          <Data ss:Type="String">Dr. Yu profile indicates subject and researcher. Unusual.</Data>
        </Cell>
        <Cell>
          <Data ss:Type="String">โปรไฟล์ของ Dr. Yu ระบุว่าเป็นทั้งเป้าหมายและนักวิจัย ผิดปกติ</Data>
        </Cell>
      </Row>
      <Row>
        <Cell>
          <Data ss:Type="String">BDDB548E56C3A3D3</Data>
        </Cell>
        <Cell>
          <Data ss:Type="String">But this is often ignored. </Data>
        </Cell>
        <Cell>
          <Data ss:Type="String">แต่สิ่งนี้มักถูกละเลย</Data>
        </Cell>
      </Row>
      <Row>
        <Cell>
          <Data ss:Type="String">BDDB548E56C3A3FF</Data>
        </Cell>
        <Cell>
          <Data ss:Type="String">Dr. Yu...</Data>
        </Cell>
        <Cell>
          <Data ss:Type="String">ดร. Yu...</Data>
        </Cell>
      </Row>
      <Row>
        <Cell>
          <Data ss:Type="String">BDDB548E56C3A470</Data>
        </Cell>
        <Cell>
          <Data ss:Type="String">Your neural patterns show signs of Typhon integration.</Data>
        </Cell>
        <Cell>
          <Data ss:Type="String">รูปแบบระบบประสาทของคุณแสดงสัญญาณของการรวมตัวกับ Typhon</Data>
        </Cell>
      </Row>
      <Row>
        <Cell>
          <Data ss:Type="String">BDDB548E56C3A497</Data>
        </Cell>
        <Cell>
          <Data ss:Type="String">Your neural pattern shows no sign of Typhon material.</Data>
        </Cell>
        <Cell>
          <Data ss:Type="String">รูปแบบระบบประสาทของคุณไม่แสดงสัญญาณของสาร Typhon</Data>
        </Cell>
      </Row>
      <Row>
        <Cell>
          <Data ss:Type="String">BDDB548E570D048F</Data>
        </Cell>
        <Cell>
          <Data ss:Type="String">I am a Sybil 495 Science Class Operator.</Data>
        </Cell>
        <Cell>
          <Data ss:Type="String">ผมคือ Operator ระดับวิทยาศาสตร์ Sybil 495</Data>
        </Cell>
      </Row>
      <Row>
        <Cell>
          <Data ss:Type="String">BDDB548E570D04E5</Data>
        </Cell>
        <Cell>
          <Data ss:Type="String">Everyone's eager to see what you're capable of, Dr. Yu.</Data>
        </Cell>
        <Cell>
          <Data ss:Type="String">ทุกคนต่างกระตือรือร้นที่จะเห็นว่าคุณมีความสามารถอะไร, Dr. Yu</Data>
        </Cell>
      </Row>
      <Row>
        <Cell>
          <Data ss:Type="String">BDDB548E570D052F</Data>
        </Cell>
        <Cell>
          <Data ss:Type="String">TranStar has over a dozen state of the art facilities across the globe. </Data>
        </Cell>
        <Cell>
          <Data ss:Type="String">TranStar มีสิ่งอำนวยความสะดวกที่ทันสมัยกว่าสิบแห่งทั่วโลก</Data>
        </Cell>
      </Row>
      <Row>
        <Cell>
          <Data ss:Type="String">BDDB548E570D0577</Data>
        </Cell>
        <Cell>
          <Data ss:Type="String">I'm sure your brother is waiting for you.</Data>
        </Cell>
        <Cell>
          <Data ss:Type="String">ผมแน่ใจว่าพี่ชายของคุณกำลังรอคุณอยู่</Data>
        </Cell>
      </Row>
      <Row>
        <Cell>
          <Data ss:Type="String">BDDB548E570D08F6</Data>
        </Cell>
        <Cell>
          <Data ss:Type="String">The elevator will take you directly to the testing area.</Data>
        </Cell>
        <Cell>
          <Data ss:Type="String">ลิฟต์จะพาคุณตรงไปยังพื้นที่ทดสอบ</Data>
        </Cell>
      </Row>
      <Row>
        <Cell>
          <Data ss:Type="String">BDDB548E570D0927</Data>
        </Cell>
        <Cell>
          <Data ss:Type="String">I know I am.</Data>
        </Cell>
        <Cell>
          <Data ss:Type="String">ผมรู้ว่าผมเป็น</Data>
        </Cell>
      </Row>
      <Row>
        <Cell>
          <Data ss:Type="String">BDDB548E570D099E</Data>
        </Cell>
        <Cell>
          <Data ss:Type="String">More, if you count the entire Earth-Moon system.</Data>
        </Cell>
        <Cell>
          <Data ss:Type="String">มากกว่านั้น ถ้าคุณนับรวมระบบโลก-ดวงจันทร์ทั้งหมด</Data>
        </Cell>
      </Row>
      <Row>
        <Cell>
          <Data ss:Type="String">BDDB548E570D0A48</Data>
        </Cell>
        <Cell>
          <Data ss:Type="String">My instruments are calibrated for high volume data analysis and live readings.</Data>
        </Cell>
        <Cell>
          <Data ss:Type="String">เครื่องมือของผมถูกปรับเทียบไว้สำหรับการวิเคราะห์ข้อมูลปริมาณมากและการอ่านค่าแบบเรียลไทม์</Data>
        </Cell>
      </Row>
      <Row>
        <Cell>
          <Data ss:Type="String">BDDB548E570D0AD9</Data>
        </Cell>
        <Cell>
          <Data ss:Type="String">Don't worry. Nothing will be missed.</Data>
        </Cell>
        <Cell>
          <Data ss:Type="String">ไม่ต้องกังวล จะไม่มีอะไรพลาดไป</Data>
        </Cell>
      </Row>
      <Row>
        <Cell>
          <Data ss:Type="String">BDDB548E570EA0CA</Data>
        </Cell>
        <Cell>
          <Data ss:Type="String">Our research often requires intense focus and long hours.</Data>
        </Cell>
        <Cell>
          <Data ss:Type="String">การวิจัยของเรามักต้องการสมาธิอย่างสูงและใช้เวลานาน</Data>
        </Cell>
      </Row>
      <Row>
        <Cell>
          <Data ss:Type="String">BDDB548E570EA0CF</Data>
        </Cell>
        <Cell>
          <Data ss:Type="String">All our labs meet the minimum--(corrupt machine sound)</Data>
        </Cell>
        <Cell>
          <Data ss:Type="String">ห้องทดลองทั้งหมดของเราเป็นไปตามมาตรฐานขั้นต่ำ--(เสียงเครื่องจักรขัดข้อง)</Data>
        </Cell>
      </Row>
      <Row>
        <Cell>
          <Data ss:Type="String">BDDB548E570EB4A4</Data>
        </Cell>
        <Cell>
          <Data ss:Type="String">I can provide you with a psychoactive stimulant after the test.</Data>
        </Cell>
        <Cell>
          <Data ss:Type="String">ผมสามารถจัดหาสารกระตุ้นจิตประสาทให้คุณหลังการทดสอบ</Data>
        </Cell>
      </Row>
      <Row>
        <Cell>
          <Data ss:Type="String">BDDB548E570EB583</Data>
        </Cell>
        <Cell>
          <Data ss:Type="String">If necessary.</Data>
        </Cell>
        <Cell>
          <Data ss:Type="String">ถ้าจำเป็น</Data>
        </Cell>
      </Row>
      <Row>
        <Cell>
          <Data ss:Type="String">BDDB548E570EB634</Data>
        </Cell>
        <Cell>
          <Data ss:Type="String">Strange. That's never happened before.</Data>
        </Cell>
        <Cell>
          <Data ss:Type="String">แปลกจัง ไม่เคยเกิดขึ้นมาก่อนเลย</Data>
        </Cell>
      </Row>
      <Row>
        <Cell>
          <Data ss:Type="String">BDDB548E570EB65D</Data>
        </Cell>
        <Cell>
          <Data ss:Type="String">I'll have to file a maintenance request.</Data>
        </Cell>
        <Cell>
          <Data ss:Type="String">ผมจะต้องยื่นคำขอซ่อมบำรุง</Data>
        </Cell>
      </Row>
      <Row>
        <Cell>
          <Data ss:Type="String">BDDB548E570EB667</Data>
        </Cell>
        <Cell>
          <Data ss:Type="String">Please excuse me, Dr. Yu.</Data>
        </Cell>
        <Cell>
          <Data ss:Type="String">ขอตัวก่อนนะครับ, Dr. Yu</Data>
        </Cell>
      </Row>
      <Row>
        <Cell>
          <Data ss:Type="String">BDDB548E57199239</Data>
        </Cell>
        <Cell>
          <Data ss:Type="String">It won't be long before you're on a shuttle bound for Talos I. </Data>
        </Cell>
        <Cell>
          <Data ss:Type="String">อีกไม่นานคุณก็จะอยู่บนกระสวยที่มุ่งหน้าสู่ Talos I</Data>
        </Cell>
      </Row>
      <Row>
        <Cell>
          <Data ss:Type="String">BDDB548E571FDA12</Data>
        </Cell>
        <Cell>
          <Data ss:Type="String">Warning! Overload instigated-ed-ed-ed-(error sounds)</Data>
        </Cell>
        <Cell>
          <Data ss:Type="String">คำเตือน! โอเวอร์โหลดถูกเริ่ม-ิ่ม-ิ่ม-ิ่ม-(เสียงข้อผิดพลาด)</Data>
        </Cell>
